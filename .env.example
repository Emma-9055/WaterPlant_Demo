# ============================================
# LLM 配置（默认 DeepSeek，国内直连）
# ============================================

# 方式一：DeepSeek（推荐，国内直连，便宜，中文强）
#          → https://platform.deepseek.com 注册获取 Key
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-...

# 方式二：Groq Cloud（免费，需海外网络）
# LLM_PROVIDER=groq
# LLM_MODEL=qwen-2.5-32b
# GROQ_API_KEY=gsk_...

# 方式三：Ollama 本地（零 API Key，需安装 Ollama）
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3:8b
# 使用前：ollama pull qwen3:8b

# 方式四：Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# 方式五：OpenAI GPT
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ============================================
# 向量存储配置
# ============================================
VECTOR_STORE_BACKEND=faiss

# ============================================
# LLM 配置（三选一，默认 Ollama 无需 API Key）
# ============================================

# 方式一：Ollama 本地模型（推荐，开源友好，零配置）
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
# 使用前需安装 Ollama 并拉取模型：
#   ollama pull qwen3:8b

# 方式二：Anthropic Claude（效果最好，需要 API Key）
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# 方式三：OpenAI GPT（需要 API Key）
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ============================================
# 向量存储配置
# ============================================
# faiss: 本地向量库，零配置（默认）
# dify:  Dify 知识库 API（需先部署 Dify）
VECTOR_STORE_BACKEND=faiss

# Dify 配置（仅 VECTOR_STORE_BACKEND=dify 时需要）
# DIFY_API_BASE=https://api.dify.ai/v1
# DIFY_API_KEY=app-...
# DIFY_DATASET_ID=...

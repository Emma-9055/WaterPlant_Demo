# ============================================
# LLM 配置（默认 Groq Cloud，免费使用开源 Qwen 模型）
# ============================================

# 方式一：Groq Cloud（推荐，免费 API，云端部署首选）
#          → https://console.groq.com 注册获取 Key
LLM_PROVIDER=groq
LLM_MODEL=qwen-2.5-32b
GROQ_API_KEY=gsk_...

# 方式二：Ollama 本地（零 API Key，需要安装 Ollama）
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3:8b
# 使用前：ollama pull qwen3:8b

# 方式三：Anthropic Claude（效果最好，需付费 API Key）
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# 方式四：OpenAI GPT（需付费 API Key）
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ============================================
# 向量存储配置
# ============================================
VECTOR_STORE_BACKEND=faiss

# Dify（可选，需先部署 Dify）
# VECTOR_STORE_BACKEND=dify
# DIFY_API_BASE=https://api.dify.ai/v1
# DIFY_API_KEY=app-...
# DIFY_DATASET_ID=...
